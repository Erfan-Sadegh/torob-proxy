FROM nginx:1.31-alpine

ENV WORKER_1_HOST=torob-proxy.erfanclash20178-calm-moon.svc
ENV WORKER_2_HOST=torob-proxy-2.erfanclash20178-calm-moon.svc
ENV WORKER_3_HOST=torob-proxy-3.erfanclash20178-calm-moon.svc
ENV WORKER_PROXY_TOKEN=change-this-token
ENV GATEWAY_PROXY_TOKEN=change-this-token
ENV CORS_ALLOW_ORIGIN=*

COPY nginx/gateway-templates /etc/nginx/templates
